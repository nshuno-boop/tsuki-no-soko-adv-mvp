# Phase 6 composition transforms.
# These intentionally replace Ren'Py's default left/center/right placement in
# story scenes so sprites read as waist-up portraits and avoid the objective UI.

transform left:
    xalign 0.16
    yalign 1.0
    yoffset 128
    zoom 0.92

transform center:
    xalign 0.5
    yalign 1.0
    yoffset 122
    zoom 0.92

transform right:
    xalign 0.84
    yalign 1.0
    yoffset 128
    zoom 0.92
